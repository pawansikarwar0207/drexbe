<div class="col-lg-11 mx-auto mb-5">
  <h1 class="text-center mb-4 mt-5">Search Results</h1>
  <div class="row g-2 mb-5">
    <div class="col-lg-12">
      <!-- Search -->
      <%= render 'shared/search_form' %>
      <!-- Search -->

        <div style="background-color: #353188;" class="text-white fs-5 p-3 mt-3 mb-3">
          <div class="row g-0">
            <div class="col-lg-6">
              Total Results: 
              <%= @travelers.size + @parcel_ads.size + @buy_for_mes.size %>
            </div>
            <div class="col-lg-4">
              
            </div>
          </div>
        </div>  
    </div>

    <div class="col-md-3">
      <%= render 'home/search_filter' %>
    </div>

    <div class="col-md-9">
      <%# Traveler Section %>
      <%= render 'search_results/traveler' %>

      <%# Sender Section %>
      <%= render 'search_results/sender' %>

      <%# buyer section %>
      <%= render 'search_results/buyer' %>
    </div>
  </div>

  <%# Add the pagination here %>
  <div class="pagination mt-3">
    <%= paginate @travelers %>
    <%= paginate @parcel_ads %>
    <%= paginate @buy_for_mes %>
  </div>
</div>

<section class="section facts-number mt-5 mb-5 p-5" style="display: flex; justify-content: center; align-items: center; flex-direction: column; background-color: #E7E5FF; ">
    <div class="container text-center" style="max-width: 1200px; padding: 0;">
      <!-- Heading title-->
      <!-- /Heading title -->
      <div class="counter-group" style="width: 100%;">
        <div class="row g-0" style="display: flex; justify-content: center; align-items: center;">
          <div class="col-lg-3 col-md-6 col-12 d-flex" data-aos="fade-down" style="display: flex; justify-content: center; align-items: center; padding: 15px;">
            <div class="count-group flex-fill" style="text-align: center;">
              <div class="customer-count d-flex align-items-center" style="justify-content: center; flex-direction: column;">
                <div class="count-content">
                  <h4><i class="fa fa-search"></i> Simple</h4>
                  <p class="text-center fs-6">Just search, click and <br> send with ease </p>
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 col-12 d-flex" data-aos="fade-down" style="display: flex; justify-content: center; align-items: center; padding: 15px;">
            <div class="count-group flex-fill" style="text-align: center;">
              <div class="customer-count d-flex align-items-center" style="justify-content: center; flex-direction: column;">
                <div class="count-content">
                  <h4><i class="fa fa-clock-o"></i> Fast</h4>
                  <p class="text-center fs-6">Same-day delivery for <br> urgent shipments </p>
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 col-12 d-flex" data-aos="fade-down" style="display: flex; justify-content: center; align-items: center; padding: 15px;">
            <div class="count-group flex-fill" style="text-align: center;">
              <div class="customer-count d-flex align-items-center" style="justify-content: center; flex-direction: column;">
                <div class="count-content">
                  <h4><%= image_tag "check-circle.svg", class: "mx-2" %></i>Trust</h4>
                  <p class="text-center fs-6">Verified carriers for <br>secure deliveries </p>
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 col-12 d-flex" data-aos="fade-down" style="display: flex; justify-content: center; align-items: center; padding: 15px;">
            <div class="count-group flex-fill" style="text-align: center;">
              <div class="customer-count d-flex align-items-center" style="justify-content: center; flex-direction: column;">
                <div class="count-content">
                  <h4><i class="fa fa-arrow-down"></i> Cheap</h4>
                  <p class="text-center fs-6">Save upto 70% on <br>your shipping costs </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%= render 'shared/experience' %>

  <section class="mt-5">
    <div class="contaier bg-light text-center p-5">
      <h2 class="fs-1">Ready to Get Started</h2>
      <p class="lead text-dark fs-4">Get Started and Use DREXBE Immediatly</p>
      <button class="start-btn mt-2">Start Now</button>
    </div>
  </section>

  <%= render 'shared/questions' %>
  <%= render 'shared/subscribe' %>

<script>
  function showContact(parcelId, phoneNumber) {
    const buttonElement = document.getElementById(`contact-button-${parcelId}`);
    buttonElement.textContent = phoneNumber;  // Replace the text with the phone number
  }

  document.addEventListener("DOMContentLoaded", function() {
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
    var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
      return new bootstrap.Tooltip(tooltipTriggerEl)
    })
  });
</script>

<script>
  AOS.init();
</script>


<style>
  #profile-button:hover {
    background-color: #353188 !important;
    border-color: #353188 !important;
    color: white ;
  }

  .pagination {
    display: flex;
    justify-content: end;
    padding: 10px;
  }

  .pagination .page-item {
    margin: 0 5px;
  }

  .pagination .page-link:hover {
    color: #0056b3;
  }

</style>
