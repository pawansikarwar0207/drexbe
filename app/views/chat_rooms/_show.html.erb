<!-- Chat Header -->
<%= turbo_frame_tag "chatroom_frame" do %>
<% end %>


<style>
  /* Copy message */
  .message-content-container {
    position: relative;
  }

  .message-content-container .copy-btn {
    display: none;
    position: absolute;
    top: 20%;
    transform: translateY(-50%);
    font-size: 12px;
    padding: 5px 10px;
    cursor: pointer;
  }

  /* Hover Effect */
  .message-content-container:hover .copy-btn {
    display: block;
  }

  /* Position for Sent Messages */
  .message-content-container.sent .copy-btn {
    right: -55px; /* Position on the left side of sent messages */
  }

  /* Position for Received Messages */
  .message-content-container.received .copy-btn {
    left: -55px; /* Position on the right side of received messages */
  }


  /* Chat Container */
  .airbnb-chat-container {
    display: flex;
    flex-direction: column;
    background-color: #f7f7f7;
    margin: 0 auto;
  }

  /* Header */
  .chat-header {
    background-color: white;
    border-bottom: 1px solid #e0e0e0;
  }

  .chat-header h6 {
    margin: 0;
    font-weight: 600;
  }

  /* Messages */
  .chat-messages {
    flex-grow: 1;
    overflow-y: auto;
    padding: 20px;
    background-color: #ffffff;
  }

  .message {
    display: flex;
    align-items: flex-start;
    margin-bottom: 15px;
    border-bottom: none;
  }

  .message.sent {
    flex-direction: row-reverse;
  }

  .message.received {
    flex-direction: row;
  }

  .avatar-container img {
    width: 30px;
    height: 30px;
    object-fit: cover;
    border-radius: 50%;
  }

  .message-content {
    max-width: 100%;
    background-color: #f7f7f7;
    border-radius: 5px;
    padding: 10px;
    box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.1);
  }

  .message.sent .message-content {
    background-color: #dcf8c6;
  }

  .message.received .message-content {
    background-color: #ffffff;
  }

  .message-text {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
  }

  /* Input */
  .chat-input {
    background-color: #ffffff;
  }

  .chat-input .form-control {
    border: 1px solid #dcdcdc;
    box-shadow: none;
  }

  .chat-input .btn {
    font-weight: bold;
  }

  .chat-messages {
    height: 71vh !important;
    overflow-y: scroll;
  }
  body {
    overflow: auto;
  }/* Adjust spacing for Reaction Buttons */
  .date-heading {
      margin: 10px 0;
    font-size: 14px;
    font-weight: bold;
    padding: 10px;
    border: #888;
    background: #f0f0f0;
    width: fit-content;
    border-radius: 15px;
}

.message-content-container {
  position: relative;
  margin: 5px 0;
  padding: 10px;
  border-radius: 8px;
  background-color: #f1f1f1;
}
.date-section {
  margin: 0 auto;
  width: fit-content;
}
</style>
