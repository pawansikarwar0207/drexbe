<h2>Hello <%= @receiver.full_name %>,</h2>

<p>You have received a new connection request from <strong><%= @sender.full_name %></strong>.</p>

<p>Click below to accept or reject the request:</p>

<!-- Accept Button -->
<a href="<%= accept_connection_request_url(@request) %>" style="background: green; color: white; padding: 10px 15px; text-decoration: none; border-radius: 5px;">
  Accept Connection
</a>

<!-- Reject Button -->
<a href="<%= reject_connection_request_url(@request) %>" style="background: red; color: white; padding: 10px 15px; text-decoration: none; border-radius: 5px; margin-left: 10px;">
  Reject Connection
</a>

<p>Thank you!</p>
